:root {
  /* SIZES */
  --space: 8px;
  --s025: calc(var(--space) * 0.25);
  --s05: calc(var(--space) * 0.5);
  --s075: calc(var(--space) * 0.75);
  --s: var(--space);
  --s15: calc(var(--space) * 1.5);
  --s2: calc(var(--space) * 2);
  --s3: calc(var(--space) * 3);
  --s4: calc(var(--space) * 4);
  --s45: calc(var(--space) * 4.5);
  --s5: calc(var(--space) * 5);
  --s6: calc(var(--space) * 6);
  --s7: calc(var(--space) * 7);
  --s8: calc(var(--space) * 8);
  --s9: calc(var(--space) * 9);
  --s10: calc(var(--space) * 10);
  --s12: calc(var(--space) * 12);
  --s14: calc(var(--space) * 14);
  --s16: calc(var(--space) * 16);
  --s18: calc(var(--space) * 18);
  --s20: calc(var(--space) * 20);
  --color-light: #ffffff;
  --color-dark-transparent-a: #ffffff88;
  --color-0: #ea6d4e;
  --color-1: #ca2721;
  --color-2: #55413d;
  --color-3: #334155;
  --color-4: hsl(90, 11%, 86%);
  --color-5: #FFFFFF;
  --color-6: #054948;
  --color-7: #111111;
  --color-8: rgba(255, 255, 255, 0.78);
  --color-info: #35ca21;
  --color-warn: var(--color-0);
  --color-error: var(--color-1);
  --color-borders: #a1a1a1;
}
:root :root {
  --fc-button-text-color: var(--color-5);
  --fc-button-bg-color: var(--color-0);
  --fc-button-border-color: var(--color-0);
  --fc-button-hover-bg-color: var(--color-1);
  --fc-button-hover-border-color: var(--color-1);
  --fc-button-active-bg-color: var(--color-1);
  --fc-button-active-border-color: var(--color-1);
  --fc-event-bg-color: var(--color-1);
  --fc-event-border-color: var(--color-1);
  --fc-event-text-color: var(--color-5);
  --fc-event-selected-overlay-color: var(--color-0);
}

.PCPPrice {
  position: relative;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}
.PCPPrice .PriceTools {
  width: 100%;
  display: flex;
  align-items: center;
  gap: var(--s05);
}
.PCPPrice .PriceTools .PostId {
  border: solid #ccc;
  border-radius: 3px;
  border-width: 1px;
  padding: 0 var(--s);
  height: 30px;
  box-sizing: border-box;
  display: flex;
  justify-content: center;
  align-items: center;
  font-weight: bold;
  background-color: var(--color-4);
}
.PCPPrice .PriceTools .Access {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 0 var(--s05);
}
.PCPPrice .PriceTools .Access .IsFree {
  margin: 1px var(--s05) 0 0;
}
.PCPPrice .PriceTools .Access label {
  text-transform: uppercase;
  cursor: pointer;
  opacity: 0.3;
}
.PCPPrice .PriceTools .Access label.Free {
  opacity: 1;
  font-weight: bold;
}

#the-list tr td.PCPPrice,
.wrap.nestedpages .nestedpages ol li .row .PCPPrice {
  width: 120px;
}

.wrap.nestedpages .nestedpages ol li .row .PCPPrice {
  display: table-cell;
  padding: 0 var(--s) 0 0;
}

#pcp_page_assign_price .inside .pricewrapper .PCPPrice .PriceForm {
  width: 100%;
}